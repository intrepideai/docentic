# docentic — environment variables
#
# Copy this file to .env and fill in a key for ONE provider. `docentic populate`
# reads it to fill the scaffolded TODOs. `docentic init` needs no keys.
#
# Provider is chosen automatically: DOCENT_PROVIDER if set, otherwise the first
# key present in the order Anthropic → OpenAI → Gemini.
#
# NOTE: .env is gitignored by `docentic init` so your key is never committed.

# ----- Anthropic (default; best repo reasoning in our testing) -----
ANTHROPIC_API_KEY=

# ----- OpenAI -----
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5
# OPENAI_BASE_URL=                      # for Azure / OpenAI-compatible gateways

# ----- Google Gemini -----
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-pro

# ----- Provider / model selection -----
# Force a provider even if multiple keys are set: anthropic | openai | gemini
# DOCENT_PROVIDER=anthropic
# Override the model for the bootstrap content fill (else the provider default):
# DOCENT_MODEL_BOOTSTRAP=claude-sonnet-4-6

# ----- Cost guard -----
# Max estimated USD per `docentic populate` run (preflight estimate; default 5).
# Also settable per-run with --max-cost.
# DOCENT_MAX_COST_USD=5.00
