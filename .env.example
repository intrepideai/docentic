# docent — environment variables
#
# Copy this file to .env and fill in the keys for the LLM provider you want
# `docent populate` to use (coming soon — currently the CLI is scaffold-only).
#
# You only need to fill in the keys for the provider(s) you actually use.
# Anthropic is the default if multiple are present.

# ----- Anthropic (default) -----
ANTHROPIC_API_KEY=

# Optional: override model class per task. Defaults shown.
# DOCENT_MODEL_BOOTSTRAP=claude-opus-4-7      # for the bootstrap content fill
# DOCENT_MODEL_CONFIG=claude-sonnet-4-7        # for config-seeder
# DOCENT_MODEL_SCOUT=claude-haiku-4-7          # for scouts (cheap)
# DOCENT_MODEL_RESEARCHER=claude-sonnet-4-7    # for per-item research

# ----- OpenAI (alternative) -----
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5
# OPENAI_BASE_URL=                             # for custom gateways

# ----- Google -----
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-pro

# ----- Provider preference -----
# Which provider to use when multiple keys are set. Default: anthropic.
# DOCENT_PROVIDER=anthropic

# ----- Cost & runtime guards -----
# Maximum USD per `docent populate` run. Aborts mid-run if exceeded.
# DOCENT_MAX_COST_USD=5.00

# Maximum runtime in seconds. Aborts if exceeded.
# DOCENT_MAX_RUNTIME_SECONDS=900

# ----- Output verbosity -----
# Set to 1 for verbose per-file logging.
# DOCENT_VERBOSE=0
